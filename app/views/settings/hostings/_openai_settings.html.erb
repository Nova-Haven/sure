<div class="space-y-4">
  <div>
    <h2 class="font-medium mb-1"><%= t(".title") %></h2>
    <% if ENV["OPENAI_ACCESS_TOKEN"].present? %>
      <p class="text-sm text-secondary"><%= t(".env_configured_message") %></p>
    <% else %>
      <p class="text-secondary text-sm mb-4"><%= t(".description") %></p>
    <% end %>
  </div>

  <%= styled_form_with model: Setting.new,
                       url: settings_hosting_path,
                       method: :patch,
                       data: {
                         controller: "auto-submit-form openai-settings",
                         "auto-submit-form-trigger-event-value": "change"
                       } do |form| %>
  
  <!-- API Access Token -->
  <%= form.password_field :openai_access_token,
                          label: t(".access_token_label"),
                          placeholder: t(".access_token_placeholder"),
                          value: (Setting.openai_access_token.present? ? "********" : nil),
                          autocomplete: "off",
                          autocapitalize: "none",
                          spellcheck: "false",
                          inputmode: "text",
                          disabled: false, # Allow overriding ENV variables
                          data: { "auto-submit-form-target": "auto" } %>

  <%= form.text_field :openai_uri_base,
                      label: t(".uri_base_label"),
                      placeholder: t(".uri_base_placeholder"),
                      value: Setting.openai_uri_base,
                      autocomplete: "off",
                      autocapitalize: "none",
                      spellcheck: "false",
                      inputmode: "url",
                      disabled: false, # Allow overriding ENV variables
                      data: { 
                        "auto-submit-form-target": "auto",
                        "openai-settings-target": "endpoint",
                        action: "change->openai-settings#endpointChanged"
                      } %>

  <!-- Model Selection Container -->
  <div data-openai-settings-target="modelContainer">
    <% 
      current_model = Setting.openai_model
      Rails.logger.info "Rendering model select with current_model: #{current_model}"
      
      # Try to get previously loaded models from session if available
      previous_models = session[:openai_models] || []
      
      initial_options = if current_model.present? && previous_models.any?
        # We have both a selected model and previously loaded models - show all
        options = [["Select a model...", ""]]
        options += previous_models.map { |model| [model, model] }
        # Ensure current model is in the list (in case it's custom)
        unless previous_models.include?(current_model)
          options << ["#{current_model} (custom)", current_model]
        end
        options
      elsif current_model.present?
        # We have a selected model but no cached models - show minimal
        [["Select a model...", ""], [current_model, current_model]]
      else
        # No selected model
        [["Select a model...", ""]]
      end
    %>
    <%= form.select :openai_model,
                    options_for_select(initial_options, current_model),
                    { 
                      selected: current_model,
                      prompt: false
                    },
                    {
                      label: t(".model_label"),
                      disabled: false, # Allow overriding ENV variables
                      data: {
                        "auto-submit-form-target": "auto",
                        "openai-settings-target": "modelSelect"
                      }
                    } %>
  </div>

  <!-- Refresh Models Button -->
  <div class="flex items-center gap-2">
    <%= render DS::Button.new(
          variant: :secondary, 
          size: :sm, 
          text: "Refresh Models",
          icon: "refresh-cw",
          data: {
            "openai-settings-target": "refreshButton",
            action: "click->openai-settings#refreshModels"
          }
        ) %>
    <span class="text-sm text-secondary" data-openai-settings-target="providerInfo"></span>
  </div>

  <!-- Suggestions for whitelist/blacklist inputs -->
  <datalist id="openai-model-suggestions" data-openai-settings-target="suggestionsList"></datalist>

  <!-- Model Whitelist -->
  <div class="mt-4">
    <label class="block text-sm font-medium mb-1">Model whitelist</label>
    <p class="text-xs text-secondary mb-2">Exact matches shown even if blacklisted. Add multiple entries.</p>
    <div data-openai-settings-target="whitelistContainer">
      <% Array(Setting.openai_model_whitelist).each do |entry| %>
        <div data-entry-row class="flex items-center gap-2 mb-2">
          <input type="text"
                 name="setting[openai_model_whitelist][]"
                 value="<%= entry %>"
                 list="openai-model-suggestions"
                 class="input w-full"
                 data-openai-settings-target="whitelist"
                 data-action="change->openai-settings#whitelistChanged" />
          <button type="button"
                  class="btn btn-ghost btn-sm"
                  data-action="click->openai-settings#removeEntry"
                  aria-label="Remove">✕</button>
        </div>
      <% end %>
      <!-- Always keep one empty row so a new entry isn't lost on autosave -->
      <div data-entry-row class="flex items-center gap-2 mb-2">
        <input type="text"
               name="setting[openai_model_whitelist][]"
               value=""
               list="openai-model-suggestions"
               class="input w-full"
               data-openai-settings-target="whitelist"
               data-action="change->openai-settings#whitelistChanged" />
        <button type="button"
                class="btn btn-ghost btn-sm"
                data-action="click->openai-settings#removeEntry"
                aria-label="Remove">✕</button>
      </div>
    </div>
    <%= render DS::Button.new(
      variant: :ghost,
      size: :sm,
          text: "Add",
          icon: "plus",
          data: { action: "click->openai-settings#addWhitelistEntry" }
        ) %>
  </div>

  <!-- Model Blacklist -->
  <div class="mt-4">
    <label class="block text-sm font-medium mb-1">Model blacklist</label>
    <p class="text-xs text-secondary mb-2">Substring match; e.g., adding "text-embedding" hides models like "text-embedding-01".</p>
    <div data-openai-settings-target="blacklistContainer">
      <% Array(Setting.openai_model_blacklist).each do |entry| %>
        <div data-entry-row class="flex items-center gap-2 mb-2">
          <input type="text"
                 name="setting[openai_model_blacklist][]"
                 value="<%= entry %>"
                 list="openai-model-suggestions"
                 class="input w-full"
                 data-openai-settings-target="blacklist"
                 data-action="change->openai-settings#blacklistChanged" />
          <button type="button"
                  class="btn btn-ghost btn-sm"
                  data-action="click->openai-settings#removeEntry"
                  aria-label="Remove">✕</button>
        </div>
      <% end %>
      <!-- Always keep one empty row so a new entry isn't lost on autosave -->
      <div data-entry-row class="flex items-center gap-2 mb-2">
        <input type="text"
               name="setting[openai_model_blacklist][]"
               value=""
               list="openai-model-suggestions"
               class="input w-full"
               data-openai-settings-target="blacklist"
               data-action="change->openai-settings#blacklistChanged" />
        <button type="button"
                class="btn btn-ghost btn-sm"
                data-action="click->openai-settings#removeEntry"
                aria-label="Remove">✕</button>
      </div>
    </div>
    <%= render DS::Button.new(
      variant: :ghost,
      size: :sm,
          text: "Add",
          icon: "plus",
          data: { action: "click->openai-settings#addBlacklistEntry" }
        ) %>
  </div>

  <% end %>
</div>
