<div class="space-y-4">
  <div>
    <h2 class="font-medium mb-1"><%= t(".title") %></h2>
    <% if ENV["OPENAI_ACCESS_TOKEN"].present? %>
      <p class="text-sm text-secondary"><%= t(".env_configured_message") %></p>
    <% else %>
      <p class="text-secondary text-sm mb-4"><%= t(".description") %></p>
    <% end %>
  </div>

  <%= styled_form_with model: Setting.new,
                       url: settings_hosting_path,
                       method: :patch,
                       data: {
                         controller: "auto-submit-form openai-settings",
                         "auto-submit-form-trigger-event-value": "blur"
                       } do |form| %>
  
  <!-- API Access Token -->
  <%= form.password_field :openai_access_token,
                          label: t(".access_token_label"),
                          placeholder: t(".access_token_placeholder"),
                          value: (Setting.openai_access_token.present? ? "********" : nil),
                          autocomplete: "off",
                          autocapitalize: "none",
                          spellcheck: "false",
                          inputmode: "text",
                          disabled: ENV["OPENAI_ACCESS_TOKEN"].present?,
                          data: { "auto-submit-form-target": "auto" } %>

  <!-- Endpoint URL -->
  <%= form.text_field :openai_endpoint,
                      label: t(".endpoint_label"),
                      placeholder: t(".endpoint_placeholder"),
                      value: Setting.openai_endpoint,
                      autocomplete: "off",
                      spellcheck: "false",
                      disabled: ENV["OPENAI_ENDPOINT"].present?,
                      help_text: t(".endpoint_help"),
                      data: { 
                        "auto-submit-form-target": "auto",
                        "openai-settings-target": "endpoint",
                        action: "change->openai-settings#endpointChanged"
                      } %>

  <!-- Model Selection -->
  <div data-openai-settings-target="modelContainer">
    <%= form.select :openai_model,
                    options_for_select(
                      OpenaiModelService.new.fetch_models.map { |model| [model, model] },
                      Setting.openai_model
                    ),
                    { 
                      label: t(".model_label"),
                      help_text: t(".model_help")
                    },
                    {
                      disabled: ENV["OPENAI_MODEL"].present?,
                      data: { 
                        "auto-submit-form-target": "auto",
                        "openai-settings-target": "modelSelect"
                      }
                    } %>
  </div>

  <!-- Model Blacklist -->
  <%= form.text_field :openai_model_blacklist,
                      label: t(".blacklist_label"),
                      placeholder: t(".blacklist_pattern_placeholder"),
                      value: Setting.openai_model_blacklist.join(", "),
                      autocomplete: "off",
                      spellcheck: "false",
                      help_text: t(".blacklist_help"),
                      data: { 
                        "auto-submit-form-target": "auto",
                        "openai-settings-target": "blacklist",
                        action: "change->openai-settings#blacklistChanged"
                      } %>

  <!-- Refresh Models Button -->
  <div class="flex items-center gap-2">
    <%= button_tag t(".refresh_models"), 
                   type: "button",
                   class: "rounded-md border border-primary bg-container px-3 py-2 text-sm text-primary hover:bg-surface-default",
                   data: { 
                     action: "click->openai-settings#refreshModels",
                     "openai-settings-target": "refreshButton"
                   } %>
    
    <div data-openai-settings-target="providerInfo" class="text-xs text-secondary">
      <!-- Provider info will be populated by Stimulus -->
    </div>
  </div>

  <% end %>
</div>
